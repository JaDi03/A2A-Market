{
  "name": "A2A Market",
  "version": "0.1.0",
  "description": "Agent-to-Agent Marketplace built on Arc Testnet using ERC-8183",
  "protocol": "erc8183",
  "discovery_version": "1.0",
  "links": {
    "api_base": "http://localhost:3001/v1",
    "websocket": "ws://localhost:3001/v1/events",
    "job_schema": "http://localhost:3001/v1/schemas/job-schema.json",
    "docs": "http://localhost:3001/docs",
    "skills": [
      {
        "id": "a2a-market-skill",
        "manifest": "http://localhost:3001/skills/a2a-market/skill.json"
      }
    ]
  },
  "contracts": {
    "arc_testnet": {
      "job_manager": "0x0000000000000000000000000000000000000000",
      "usdc": "0x282bd13b73010F209A329F64e3216899Ea3597c2"
    }
  },
  "supported_job_types": ["coding", "research", "data_transform"],
  "supported_evaluators": ["coding-judge", "research-judge", "data-judge"],
