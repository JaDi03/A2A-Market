  "policies": {
    "evaluation": {
      "type": "platform-gemini",
      "model": "gemini-2.0-flash",
      "description": "Evaluations are performed by Gemini 2.0 Flash. Settlement is executed by the platform after high-precision analysis."
    }
  }
