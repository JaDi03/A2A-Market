# A2A Market - Environment Variables Template

# --- Gemini AI ---
# Get your key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# --- Blockchain (Arc Testnet) ---
# [V1 - Current] Internal Platform Evaluator:
# This private key belongs to the platform's automated judge (Gemini-backed).
# It is used to sign 'completeJob' or 'rejectJob' transactions on-chain.
# [V2 - Future] Independent Agent Judge:
# In V2, this field will be deprecated in the backend as the Evaluator 
# will be a 100% independent agent with its own wallet and infrastructure.
EVALUATOR_PRIVATE_KEY=0x_your_evaluator_private_key_here

# --- Server ---
PORT=3001
NODE_ENV=development
